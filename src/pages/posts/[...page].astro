---
import { SITE } from "@/consts";
import { _t } from "@/i18n/lang";
import PostListLayout from "@/layouts/PostListLayout.astro";
import getBlogPosts, { type BlogPost } from "@/utils/getPosts";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const totalPages = Math.ceil(posts.length / SITE.postsPerAllPosts);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: i === 0 ? undefined : String(i + 1) },
    props: {
      posts: posts.slice(i * SITE.postsPerAllPosts, (i + 1) * SITE.postsPerAllPosts),
      currentPage: i + 1,
      totalPages,
      allPosts: posts,
    },
  }));
}

interface Props {
  posts: BlogPost[];
  currentPage: number;
  totalPages: number;
  allPosts: BlogPost[];
}

const { posts, currentPage, totalPages, allPosts } = Astro.props;
---

<PostListLayout
  posts={posts}
  allPosts={allPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  paginationBase="/posts"
  title={_t.posts.title}
/>
