---
import IconDotsVertical from "@/assets/icons/dots-vertical.svg";
import IconSearch from "@/assets/icons/search.svg";
import IconX from "@/assets/icons/x.svg";
import HeaderLink from "@/components/HeaderLink.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { _t, SITE } from "@/config";
---

<header>
  <nav aria-label="Main navigation">
    <span class="site-title"><a href="/">{SITE.title}</a></span>
    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <IconDotsVertical class="icon-open" />
      <IconX class="icon-close" />
    </button>
    <div class="internal-links">
      <HeaderLink href="/posts">{_t.posts.title}</HeaderLink>
      <HeaderLink href="/about">{_t.about.title}</HeaderLink>
      <HeaderLink href="/search" class="header-icon-link" aria-label={_t.search.title}
        ><IconSearch class="search-icon" /><span class="search-label">{_t.search.title}</span
        ></HeaderLink
      >
      <ThemeToggle />
    </div>
  </nav>
</header>

<script is:inline define:vars={{ __DEV__: import.meta.env.DEV }}>
  (function () {
    function initMenu() {
      if (__DEV__) console.debug("init header menu");

      const toggle = document.querySelector(".menu-toggle");
      const header = document.querySelector("header");
      if (!toggle || !header) return;

      toggle.addEventListener("click", () => {
        if (__DEV__) console.debug("toggle header menu");
        const open = header.classList.toggle("open");
        toggle.setAttribute("aria-expanded", String(open));
      });
    }

    document.addEventListener("astro:page-load", initMenu);
  })();
</script>

<style>
  @import "@/styles/breakpoints.css";

  header {
    margin: 0;
    padding: 0.5em 1em;
    border: none;
    border-bottom: 1px solid var(--color-500);
    font-weight: var(--font-weight-light);
  }
  @media (--bp-md) {
    header {
      padding: 0 3em;
    }
  }
  .site-title {
    margin: 0;
    font-size: 1em;
    font-weight: var(--font-weight-bold);
  }
  .site-title a,
  .site-title a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .internal-links {
    display: flex;
    align-items: center;
  }
  nav a {
    padding: 1em;
    color: var(--color-900);
    border-bottom: 2px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--color-900);
  }
  :global(nav a.header-icon-link) {
    display: flex;
    align-items: center;
  }
  :global(.search-label) {
    display: none;
  }

  :global(.icon-close) {
    display: none;
  }
  :global(header.open .icon-open) {
    display: none;
  }
  :global(header.open .icon-close) {
    display: block;
  }

  /* mobile menu */
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    padding: 0.5em;
    cursor: pointer;
    color: var(--color-900);
    line-height: 0;
  }

  @media not (--bp-md) {
    :global(.search-icon) {
      display: none;
    }
    :global(.search-label) {
      display: inline;
    }
    .menu-toggle {
      display: flex;
      align-items: center;
    }
    .internal-links {
      display: none;
    }
    :global(header.open) nav {
      flex-wrap: wrap;
    }
    :global(header.open) .internal-links {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
    }
  }
</style>
