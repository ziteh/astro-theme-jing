---
import { _t } from "@/config";

interface Props {
  date: Date;
}

const { date } = Astro.props;

// HACK: Use "sv-SE" locale to get the date in "YYYY-MM-DD" format
const dtAttr = date.toLocaleDateString("sv-SE", { timeZone: _t.timeZone });
---

<time datetime={dtAttr}>
  {_t.date.shortFormat(date)}
</time>
