---
import "@/styles/post.css";
import type { CollectionEntry } from "astro:content";
import IconLeft from "@/assets/icons/chevron-left.svg";
import IconRight from "@/assets/icons/chevron-right.svg";
import IconMenu from "@/assets/icons/menu-2.svg";
import Disqus from "@/components/comments/Disqus.astro";
import Giscus from "@/components/comments/Giscus.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import TagPill from "@/components/TagPill.astro";
import { SITE } from "@/consts";
import { _t } from "@/i18n/lang";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { slugifyStr } from "@/utils/slugify";

type Props = CollectionEntry<"blog">["data"] & {
  prevPost: CollectionEntry<"blog"> | null;
  nextPost: CollectionEntry<"blog"> | null;
};

const { title, description, categories, date, updated, toc, comments, tags, prevPost, nextPost } =
  Astro.props;
const ogImage = `${Astro.url.pathname.replace(/\.html$/, "").replace(/\/$/, "")}-og.png`;
---

<BaseLayout title={title} description={description || ""} ogType="article" image={ogImage}>
  {
    toc && (
      <link
        slot="head"
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/tocbot/4.36.4/tocbot.min.css"
        integrity="sha512-/ANQiHMqpRl+E0zEAd250N21OOmJsYbhiJWY0Y8yG0TII47yZn1+gDNobMlf+h/FTyImprLXYgXbX3bCYyq/vg=="
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
        media="print"
        onload="this.media='all'"
      />
    )
  }
  <main id="main-content">
    <article>
      <div class="prose">
        <div class="title">
          <h1>{title}</h1>
          <span class="date">
            <FormattedDate date={updated ?? date} />
            {updated && <span>, {_t.date.postedOn(_t.date.shortFormat(date))}</span>}
          </span>
          {
            categories.length > 0 && (
              <span class="categories">
                {categories.map((category, index) => (
                  <>
                    {index > 0 && ", "}
                    <a href={`/categories/${slugifyStr(category)}`} data-astro-prefetch>
                      {category}
                    </a>
                  </>
                ))}
              </span>
            )
          }
        </div>
        <div class="content-wrapper">
          <div class="main-content" data-pagefind-body>
            <slot />
          </div>
          <div class="sidebar-overlay" aria-hidden="true"></div>
          <button class="sidebar-fab" aria-label="Toggle sidebar" type="button">
            <IconMenu />
          </button>
        </div>
        <hr />
        <ul class="tag-list">
          {
            tags &&
              tags.map((tag) => (
                <li>
                  <TagPill id={slugifyStr(tag)} name={tag} />
                </li>
              ))
          }
        </ul>
        <nav class="post-nav" aria-label="Post navigation">
          {
            nextPost && (
              <a href={`/posts/${nextPost.id}`} class="post-nav-next" data-astro-prefetch>
                <span class="post-nav-label">
                  <IconLeft />
                </span>
                <span class="post-nav-title">{nextPost.data.title}</span>
              </a>
            )
          }
          {
            prevPost && (
              <a href={`/posts/${prevPost.id}`} class="post-nav-prev" data-astro-prefetch>
                <span class="post-nav-title">{prevPost.data.title}</span>
                <span class="post-nav-label">
                  <IconRight />
                </span>
              </a>
            )
          }
        </nav>
      </div>
    </article>
    <!-- Comments -->
    {
      comments && (
        <div id="comments">
          {SITE.disqusShortname && (
            <Disqus url={new URL(Astro.url.pathname, Astro.site).toString()} identifier={title} />
          )}
          {SITE.giscusRepo && <Giscus />}
        </div>
      )
    }
  </main>
  <aside class="sidebar">
    {toc && <div class="toc" />}
    {toc && <hr />}
    <div class="back-to-top">
      <button id="back-to-top" type="button">{_t.common.backToTop}</button>
    </div>
  </aside>
</BaseLayout>

<style is:global>
  /* tocbot */
  .toc > .toc-list {
    padding-left: 0;
  }
  .toc-link {
    text-decoration: none;
    overflow: hidden;
    white-space: nowrap;
  }
  /* a.toc-link {
    color: var(--color-700);
  } */
  .toc-link::before {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    function initSidebar() {
      const fab = document.querySelector(".sidebar-fab");
      const sidebar = document.querySelector(".sidebar");
      const overlay = document.querySelector(".sidebar-overlay");
      if (!fab || !sidebar || !overlay) return;

      function toggle() {
        sidebar.classList.toggle("open");
        overlay.classList.toggle("open");
      }
      fab.addEventListener("click", toggle);
      overlay.addEventListener("click", toggle);
    }

    initSidebar();
    document.addEventListener("astro:page-load", initSidebar);
  })();
</script>
<script is:inline>
  (function () {
    function initBackToTop() {
      const backToTop = document.getElementById("back-to-top");
      if (!backToTop) return;
      backToTop.addEventListener("click", () => {
        document.body.scrollTop = 0; // For Safari
        document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera
      });
    }

    initBackToTop();
    document.addEventListener("astro:page-load", initBackToTop);
  })();
</script>
<script is:inline>
  window.initTocbot = function () {
    if (window.tocbot) {
      window.tocbot.destroy();
      window.tocbot.init({
        tocSelector: ".toc",
        contentSelector: ".main-content",
        headingSelector: "h2, h3, h4",
        hasInnerContainers: true,
        scrollSmoothDuration: 250,
        headingsOffset: 20,
        scrollSmoothOffset: -20,
        scrollHandlerTimeout: 10,
      });
    }
  };
  document.addEventListener("astro:page-load", function () {
    if (window.tocbot && document.querySelector(".toc")) {
      window.initTocbot();
    }
  });
</script>
<script
  is:inline
  async
  src="https://cdnjs.cloudflare.com/ajax/libs/tocbot/4.36.4/tocbot.min.js"
  integrity="sha512-BZUSsJAPNtkd+kdY/bD7hvQKZ5zlgWt++KGy/Pa/5uEJNgs0jZ6JaX6MuclRUanowuxmhb5S3LRPEa3QmrUVfA=="
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
  onload="window.initTocbot()"></script>
