---
import BaseLayout from "../layouts/BaseLayout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description || "About"}>
  <section>
    <h1>{frontmatter.title}</h1>
    <slot />
  </section>
</BaseLayout>
