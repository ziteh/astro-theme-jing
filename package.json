{
  "name": "astro-theme-jing",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "biome check --write",
    "lint:check": "biome check",
    "test:a11y": "playwright test",
    "test:lh": "pnpm build && lhci autorun",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@microflash/rehype-figure": "^2.1.4",
    "astro": "^6.1.3",
    "astro-expressive-code": "^0.41.7",
    "astro-pagefind": "^1.8.6",
    "lodash.kebabcase": "^4.1.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "2.4.10",
    "@lhci/cli": "^0.15.1",
    "@playform/compress": "0.2.2",
    "@playwright/test": "^1.59.1",
    "@types/lodash.kebabcase": "^4.1.9",
    "astro-compressor": "^1.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "*.{js,ts,cjs,mjs,jsx,tsx,json,jsonc,css,astro}": "biome check --write --no-errors-on-unmatched"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1"
}
