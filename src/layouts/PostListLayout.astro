---
import IconMenu from "@/assets/icons/menu-2.svg";
import Pagination from "@/components/Pagination.astro";
import PostCard from "@/components/PostCard.astro";
import TagPill from "@/components/TagPill.astro";
import { _t, SITE } from "@/config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { BlogPost } from "@/utils/getPosts";
import getUniqueCategories from "@/utils/getUniqueCategories";
import getUniqueTags from "@/utils/getUniqueTags";
import "@/styles/sidebar.css";

interface Props {
  posts: BlogPost[];
  allPosts: BlogPost[];
  currentPage: number;
  totalPages: number;
  paginationBase: string;
  activeTagId?: string;
  activeCategoryId?: string;
  title?: string;
}

const {
  posts,
  allPosts,
  currentPage,
  totalPages,
  paginationBase,
  activeTagId,
  activeCategoryId,
  title = SITE.title,
} = Astro.props;
const categories = getUniqueCategories(allPosts);
const tags = getUniqueTags(allPosts);
---

<BaseLayout title={title} description={SITE.description}>
  <div class="page-layout">
    <main id="main-content" class="content-wrapper">
      <section>
        <h1 class="sr-only">{_t.posts.title}</h1>
        <ul class="post-list">
          {
            posts.map((post) => (
              <li>
                <PostCard
                  id={post.id}
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.date}
                  updated={post.data.updated}
                />
              </li>
            ))
          }
        </ul>
        <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={paginationBase} />
      </section>
    </main>
    <aside class="sidebar">
      <h2>{_t.tags.title}</h2>
      <ul class="tags">
        {
          tags.map((tag) => (
            <li>
              <TagPill
                id={tag.id}
                name={tag.name}
                count={tag.count}
                active={tag.id === activeTagId}
              />
            </li>
          ))
        }
      </ul>
      {categories.length > 0 && <h2>{_t.categories.title}</h2>}
      <ul class="categories">
        {
          categories.map((category) => (
            <li>
              <a
                href={category.id === activeCategoryId ? "/posts" : `/categories/${category.id}`}
                class:list={[{ active: category.id === activeCategoryId }]}
                data-astro-prefetch
              >
                <span>{category.name}</span>
                <span class="count">{category.count}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <h2>{_t.archives.title}</h2>
      <a class="archives-link" href="/archives">{_t.archives.desc}</a>
    </aside>
    <div class="sidebar-overlay" aria-hidden="true"></div>
    <button class="sidebar-fab" aria-label="Toggle sidebar" type="button">
      <IconMenu />
    </button>
  </div>
</BaseLayout>

<style>
  @import "@/styles/breakpoints.css";

  ul {
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
  .page-layout {
    position: relative;
    max-width: var(--content-width);
    margin: 0 auto;
  }
  .content-wrapper {
    margin: 0 auto;
  }
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .sidebar h2 {
    margin: 0 0 0.75rem 0;
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-normal);
  }
  .sidebar h2:not(:first-child) {
    margin-top: 2.5rem;
  }
  .sidebar {
    justify-content: flex-start;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .categories li {
    margin-bottom: 0.4rem;
  }
  .categories a {
    display: flex;
    justify-content: space-between;
    font-size: var(--font-size-sm);
    text-decoration: none;
    padding: 0.15rem 0.45rem;
    color: var(--color-700);
    border-radius: 4px;
  }
  .categories a.active,
  .categories a:hover {
    color: var(--color-900);
    background-color: var(--color-300);
  }
  .categories .count {
    font-family: var(--font-mono);
    opacity: 0.6;
  }
  .archives-link {
    font-size: var(--font-size-sm);
    text-decoration: none;
    color: var(--color-700);
  }
  .archives-link:hover {
    color: var(--color-900);
  }
  @media (--bp-lg) {
    .page-layout {
      display: grid;
      grid-template-columns: 1fr clamp(150px, 22vw, 280px);
      column-gap: clamp(3rem, 7vw, 8rem);
      max-width: calc(var(--content-width) + clamp(3rem, 7vw, 8rem) + clamp(150px, 22vw, 280px));
      align-items: start;
    }
    .content-wrapper {
      margin: 0;
      max-width: var(--content-width);
    }
    .sidebar,
    .sidebar.open {
      position: static;
      grid-column: auto;
      grid-row: auto;
      align-self: start;
      margin-left: 0;
      width: auto;
      height: auto;
      max-height: none;
      overflow-y: visible;
      background: none;
      padding: 3em 1em;
      z-index: auto;
      transform: none;
      transition: none;
    }
    .sidebar h2 {
      font-size: var(--font-size-xs);
    }
  }
</style>

<script is:inline define:vars={{ __DEV__: import.meta.env.DEV }}>
  (function () {
    function initSidebar() {
      if (__DEV__) console.debug("init sidebar");

      const fab = document.querySelector(".sidebar-fab");
      const sidebar = document.querySelector(".page-layout .sidebar");
      const overlay = document.querySelector(".sidebar-overlay");
      if (!fab || !sidebar || !overlay) return;
      if (fab.dataset.sidebarInit) return;
      fab.dataset.sidebarInit = "1";

      function toggle() {
        if (__DEV__) console.debug("toggle sidebar");
        sidebar.classList.toggle("open");
        overlay.classList.toggle("open");
      }
      fab.addEventListener("click", toggle);
      overlay.addEventListener("click", toggle);
    }

    if (window.__sidebarListener) {
      document.removeEventListener("astro:page-load", window.__sidebarListener);
    }
    window.__sidebarListener = initSidebar;
    document.addEventListener("astro:page-load", initSidebar);
  })();
</script>
