---
import type { CollectionEntry } from "astro:content";
import Pagination from "@/components/Pagination.astro";
import { SITE } from "@/consts";
import { _t } from "@/i18n/lang";
import BaseLayout from "@/layouts/BaseLayout.astro";
import getBlogPosts from "@/utils/getPosts";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const totalPages = Math.ceil(posts.length / SITE.postsPerArchives);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: i === 0 ? undefined : String(i + 1) },
    props: {
      posts: posts.slice(i * SITE.postsPerArchives, (i + 1) * SITE.postsPerArchives),
      currentPage: i + 1,
      totalPages,
      allPosts: posts,
    },
  }));
}

interface Props {
  posts: CollectionEntry<"blog">[];
  currentPage: number;
  totalPages: number;
  allPosts: CollectionEntry<"blog">[];
}

const { posts, currentPage, totalPages, allPosts } = Astro.props;

// Group posts by year, preserving sort order
const postsByYear = posts.reduce<Record<number, typeof posts>>((acc, post) => {
  const year = post.data.updated ? post.data.updated.getFullYear() : post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});
const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<BaseLayout title={_t.archives.title} description={_t.archives.desc}>
  <main id="main-content">
    <section>
      <div class="title">
        <h1>{_t.archives.title}</h1>
        <span>{_t.archives.total(allPosts.length)}</span>
      </div>
      {
        years.map((year) => (
          <div class="year-group">
            <h2 class="year-heading">{year}</h2>
            <ul class="post-list">
              {postsByYear[year].map((post) => (
                <li>
                  <a href={`/posts/${post.id}`} class="post-item">
                    <span>{post.data.title}</span>
                    {/* HACK: Use "sv-SE" locale to get the date in "YYYY-MM-DD" format */}
                    <time
                      datetime={
                        post.data.updated
                          ? post.data.updated.toLocaleDateString("sv-SE", {
                              timeZone: SITE.timeZone,
                            })
                          : post.data.date.toLocaleDateString("sv-SE", {
                              timeZone: SITE.timeZone,
                            })
                      }
                    >
                      {_t.date.monthDay(post.data.updated ?? post.data.date)}
                    </time>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/archives" />
    </section>
  </main>
</BaseLayout>

<style>
  .title {
    margin-bottom: 2.5em;
    padding: 1em 0;
    line-height: 1;
  }
  .title h1 {
    margin: 0 0 0.5em 0;
    font-weight: var(--font-weight-normal);
  }
  .title span {
    color: var(--color-700);
  }
  .year-group {
    margin-bottom: 2.5rem;
  }
  .year-heading {
    font-size: 0.875rem;
    font-weight: var(--font-weight-normal);
    color: var(--color-700);
    margin: 0 0 0.75rem 0;
    padding: 0.25em 0.5em;
  }
  .post-list {
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
  .post-list li {
    margin-bottom: 0.5rem;
  }
  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    padding: 0.25em 0.5em;
  }
  .post-item:hover {
    background-color: var(--color-300);
    border-radius: 4px;
  }
  .post-item time {
    font-size: 0.875rem;
    color: var(--color-700);
  }
</style>
