---
import { getCollection } from "astro:content";
import { SITE } from "../../../consts";
import PostListLayout from "../../../layouts/PostListLayout.astro";
import getUniqueTags from "../../../utils/getUniqueTags";
import postFilter from "../../../utils/postFilter";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(postFilter)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  const tags = getUniqueTags(posts);

  return tags.flatMap((tag) => {
    const taggedPosts = posts.filter((post) => post.data.tags.includes(tag.name));
    const totalPages = Math.ceil(taggedPosts.length / SITE.postsPerPage);

    return Array.from({ length: totalPages }, (_, i) => ({
      params: { tagId: tag.id, page: i === 0 ? undefined : String(i + 1) },
      props: {
        posts: taggedPosts.slice(i * SITE.postsPerPage, (i + 1) * SITE.postsPerPage),
        currentPage: i + 1,
        totalPages,
        allPosts: posts,
        activeTagId: tag.id,
      },
    }));
  });
}

interface Props {
  posts: any[];
  currentPage: number;
  totalPages: number;
  allPosts: any[];
  activeTagId: string;
}

const { posts, currentPage, totalPages, allPosts, activeTagId } = Astro.props;
---

<PostListLayout
  posts={posts}
  allPosts={allPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  paginationBase={`/tags/${activeTagId}`}
  activeTagId={activeTagId}
/>
