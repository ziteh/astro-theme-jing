---
import PostCard from "@/components/PostCard.astro";
import { SITE } from "@/consts";
import { _t } from "@/i18n/lang";
import BaseLayout from "@/layouts/BaseLayout.astro";
import getDescription from "@/utils/getDescription";
import getBlogPosts from "@/utils/getPosts";

const posts = (await getBlogPosts()).slice(0, SITE.postsPerHomepage);
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <section>
    <h1 class="sr-only">{SITE.title}</h1>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <PostCard
              id={post.id}
              title={post.data.title}
              description={post.data.description || getDescription(post.body || "")}
              date={post.data.date}
              updated={post.data.updated}
            />
          </li>
        ))
      }
    </ul>
    <div class="view-all">
      <a href="/posts/">{_t.common.viewAllPosts}</a>
    </div>
  </section>
</BaseLayout>

<style>
  ul {
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
  .view-all {
    margin-top: 2rem;
    text-align: center;
  }
  .view-all a {
    text-decoration: none;
  }
  .post-list {
    gap: 1rem;
  }
</style>
