---
import { _t } from "@/i18n/lang";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title={_t.notFound.title} description={_t.notFound.desc}>
  <div class="not-found">
    <span><code class="not-found-404">404</code></span>
    <h1 class="not-found-title">{_t.notFound.title}</h1>
    <p class="not-found-desc">{_t.notFound.desc}</p>
    <p class="not-found-search"><a href="/search">{_t.search.title}</a></p>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .not-found-404 {
    font-size: 4rem;
    background-color: var(--color-100);
  }
  .not-found-title {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .not-found-desc {
    font-size: 1.25rem;
    margin-bottom: 2rem;
  }
  .not-found-search {
    font-size: 1.25rem;
  }
</style>
