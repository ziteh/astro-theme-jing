---
interface Props {
  id: string;
  name: string;
  count?: number;
  active?: boolean;
}

const { id, name, count, active } = Astro.props;
---

<a href={active ? "/blog/" : `/tags/${id}/`}>
  <div class={`tag-pill ${active ? "active" : ""}`}>
    <span>{name}</span>
    {count !== undefined && <span class="count">{count}</span>}
  </div>
</a>

<style>
  .tag-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border-radius: 5px;
    border: 1px solid var(--border);
    font-size: 0.85rem;
    text-decoration: none;
  }
  .tag-pill.active {
    color: var(--text);
    background-color: var(--text-muted);
  }
  span {
    display: inline-block;
  }
  .count {
    font-family: var(--font-mono);
    margin-left: 0.5rem;
    font-size: 0.75rem;
  }
</style>
