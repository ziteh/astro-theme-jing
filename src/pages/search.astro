---
import SearchComponent from "astro-pagefind/components/Search";
import { _t } from "@/i18n/lang";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title={_t.search.title} description={_t.search.desc}>
  <main id="main-content">
    <h1 class="sr-only">{_t.search.title}</h1>
    <SearchComponent id="search" className="pagefind-ui" uiOptions={{ showImages: false }} />
  </main>
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const input = document.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
    if (input) {
      input.setAttribute("aria-label", input.title || "Search");
    }
  });
</script>
