---
import "@/styles/post.css";
import type { CollectionEntry } from "astro:content";
import IconLeft from "@/assets/icons/chevron-left.svg";
import IconRight from "@/assets/icons/chevron-right.svg";
import IconMenu from "@/assets/icons/menu-2.svg";
import Disqus from "@/components/comments/Disqus.astro";
import Giscus from "@/components/comments/Giscus.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import TagPill from "@/components/TagPill.astro";
import TocScript from "@/components/TocScript.astro";
import { SITE } from "@/consts";
import { _t } from "@/i18n/lang";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { slugifyStr } from "@/utils/slugify";

type Props = CollectionEntry<"blog">["data"] & {
  prevPost: CollectionEntry<"blog"> | null;
  nextPost: CollectionEntry<"blog"> | null;
};

const { title, description, categories, date, updated, toc, comments, tags, prevPost, nextPost } =
  Astro.props;
const ogImage = `${Astro.url.pathname.replace(/\.html$/, "").replace(/\/$/, "")}-og.png`;
---

<BaseLayout title={title} description={description || ""} ogType="article" image={ogImage}>
  <main id="main-content">
    <article class="prose">
      <header class="title">
        <h1>{title}</h1>
        <p class="meta">
          <span class="date">
            <FormattedDate date={updated ?? date} />
            {updated && <span>, {_t.date.postedOn(_t.date.shortFormat(date))}</span>}
          </span>
          {
            categories.length > 0 && (
              <span class="categories">
                {categories.map((category, index) => (
                  <>
                    {index > 0 && ", "}
                    <a href={`/categories/${slugifyStr(category)}`} data-astro-prefetch>
                      {category}
                    </a>
                  </>
                ))}
              </span>
            )
          }
        </p>
      </header>
      <div class="main-content" data-pagefind-body>
        <slot />
      </div>
      <footer>
        <hr />
        <ul class="tag-list">
          {
            tags &&
              tags.map((tag) => (
                <li>
                  <TagPill id={slugifyStr(tag)} name={tag} />
                </li>
              ))
          }
        </ul>
        <nav class="post-nav" aria-label="Post navigation">
          {
            nextPost && (
              <a href={`/posts/${nextPost.id}`} class="post-nav-next" data-astro-prefetch>
                <span class="post-nav-label">
                  <IconLeft />
                </span>
                <span class="post-nav-title">{nextPost.data.title}</span>
              </a>
            )
          }
          {
            prevPost && (
              <a href={`/posts/${prevPost.id}`} class="post-nav-prev" data-astro-prefetch>
                <span class="post-nav-title">{prevPost.data.title}</span>
                <span class="post-nav-label">
                  <IconRight />
                </span>
              </a>
            )
          }
        </nav>
      </footer>
    </article>
    <div class="sidebar-overlay" aria-hidden="true"></div>
    <button class="sidebar-fab" aria-label="Toggle sidebar" type="button">
      <IconMenu />
    </button>
    {
      comments && (
        <section id="comments" aria-label="Comments">
          {SITE.disqusShortname && (
            <Disqus url={new URL(Astro.url.pathname, Astro.site).toString()} identifier={title} />
          )}
          {SITE.giscusRepo && <Giscus />}
        </section>
      )
    }
  </main>
  <aside class="sidebar">
    {toc && <nav class="toc" aria-label="Table of contents" />}
    {toc && <hr />}
    <button class="back-to-top" id="back-to-top" type="button">{_t.common.backToTop}</button>
  </aside>
</BaseLayout>

<script is:inline>
  (function () {
    function initSidebar() {
      const fab = document.querySelector(".sidebar-fab");
      const sidebar = document.querySelector(".sidebar");
      const overlay = document.querySelector(".sidebar-overlay");
      if (!fab || !sidebar || !overlay) return;

      function toggle() {
        sidebar.classList.toggle("open");
        overlay.classList.toggle("open");
      }
      fab.addEventListener("click", toggle);
      overlay.addEventListener("click", toggle);
    }

    initSidebar();
    document.addEventListener("astro:page-load", initSidebar);
  })();
</script>
<script is:inline>
  (function () {
    function initBackToTop() {
      const backToTop = document.getElementById("back-to-top");
      if (!backToTop) return;
      backToTop.addEventListener("click", () => {
        document.body.scrollTop = 0; // For Safari
        document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera
      });
    }

    initBackToTop();
    document.addEventListener("astro:page-load", initBackToTop);
  })();
</script>

{toc && <TocScript />}
