---
import type { CollectionEntry } from "astro:content";
import { SITE } from "@/consts";
import PostListLayout from "@/layouts/PostListLayout.astro";
import getBlogPosts from "@/utils/getPosts";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const totalPages = Math.ceil(posts.length / SITE.postsPerPage);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: i === 0 ? undefined : String(i + 1) },
    props: {
      posts: posts.slice(i * SITE.postsPerPage, (i + 1) * SITE.postsPerPage),
      currentPage: i + 1,
      totalPages,
      allPosts: posts,
    },
  }));
}

interface Props {
  posts: CollectionEntry<"blog">[];
  currentPage: number;
  totalPages: number;
  allPosts: CollectionEntry<"blog">[];
}

const { posts, currentPage, totalPages, allPosts } = Astro.props;
---

<PostListLayout
  posts={posts}
  allPosts={allPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  paginationBase="/posts"
/>
