---
import { type CollectionEntry, getCollection } from "astro:content";
import { SITE } from "@/consts";
import PostListLayout from "@/layouts/PostListLayout.astro";
import getUniqueCategories from "@/utils/getUniqueCategories";
import postFilter from "@/utils/postFilter";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(postFilter)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  const categories = getUniqueCategories(posts);

  return categories.flatMap((category) => {
    const categorizedPosts = posts.filter((post) => post.data.categories.includes(category.name));
    const totalPages = Math.ceil(categorizedPosts.length / SITE.postsPerPage);

    return Array.from({ length: totalPages }, (_, i) => ({
      params: { categoryId: category.id, page: i === 0 ? undefined : String(i + 1) },
      props: {
        posts: categorizedPosts.slice(i * SITE.postsPerPage, (i + 1) * SITE.postsPerPage),
        currentPage: i + 1,
        totalPages,
        allPosts: posts,
        activeCategoryId: category.id,
      },
    }));
  });
}

interface Props {
  posts: CollectionEntry<"blog">[];
  currentPage: number;
  totalPages: number;
  allPosts: CollectionEntry<"blog">[];
  activeCategoryId: string;
}

const { posts, currentPage, totalPages, allPosts, activeCategoryId } = Astro.props;
---

<PostListLayout
  posts={posts}
  allPosts={allPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  paginationBase={`/categories/${activeCategoryId}`}
  activeCategoryId={activeCategoryId}
/>
