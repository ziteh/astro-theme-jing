---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import PostCard from "../../components/PostCard.astro";
import TagPill from "../../components/TagPill.astro";
import { SITE } from "../../consts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import getUniqueCategories from "../../utils/getUniqueCategories";
import getUniqueTags from "../../utils/getUniqueTags";
import postFilter from "../../utils/postFilter";
import Pagination from "../../components/Pagination.astro";
import getDescription from "../../utils/getDescription";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(postFilter)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  const totalPages = Math.ceil(posts.length / SITE.postsPerPage);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: i === 0 ? undefined : String(i + 1) },
    props: {
      posts: posts.slice(i * SITE.postsPerPage, (i + 1) * SITE.postsPerPage),
      currentPage: i + 1,
      totalPages,
      allPosts: posts,
    },
  }));
}

interface Props {
  posts: any[];
  currentPage: number;
  totalPages: number;
  allPosts: any[];
}

const { posts, currentPage, totalPages, allPosts } = Astro.props;
---

<BaseLayout>
  <head>
    <BaseHead title={SITE.title} description={SITE.description} />
    <style>
      ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      .content-wrapper {
        display: flex;
        gap: 2rem;
      }
      .post-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .sidebar {
        width: 140px;
        padding: 1rem;
      }
      .sidebar h2 {
        margin: 2rem 0 1rem 0;
        font-size: 1.25rem;
      }
      .tags {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="content-wrapper">
        <aside class="sidebar">
          <h2>Tags</h2>
          <ul class="tags">
            {
              getUniqueTags(allPosts).map((tag) => (
                <li>
                  <TagPill id={tag.id} name={tag.name} count={tag.count} />
                </li>
              ))
            }
          </ul>
          <h2>Categories</h2>
          <ul class="categories">
            {
              getUniqueCategories(allPosts).map((category) => (
                <li>
                  <a href={`/categories/${category.id}`}>
                    <span>{category.name}</span>
                    <span>{category.count}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </aside>
        <div>
          <ul class="post-list">
            {
              posts.map((post) => (
                <li>
                  <PostCard
                    id={post.id}
                    title={post.data.title}
                    description={post.data.description || getDescription(post.body || "")}
                    date={post.data.date}
                    updated={post.data.updated}
                  />
                </li>
              ))
            }
          </ul>
          <Pagination currentPage={currentPage} totalPages={totalPages} />
        </div>
      </section>
    </main>
    <Footer />
  </body>
</BaseLayout>
