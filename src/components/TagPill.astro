---
interface Props {
  id: string;
  name: string;
  count?: number;
  active?: boolean;
}

const { id, name, count, active } = Astro.props;
---

<a href={active ? "/posts" : `/tags/${id}`}>
  <div class={`tag-pill ${active ? "active" : ""}`}>
    <span>{name}</span>
    {count !== undefined && <span class="count">{count}</span>}
  </div>
</a>

<style>
  a {
    text-decoration: none;
  }
  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    background-color: var(--bg-secondary, transparent);
    font-size: 0.8rem;
    letter-spacing: 0.01em;
    color: var(--text-muted);
  }
  a:hover .tag-pill {
    color: var(--text);
    border-color: var(--text);
  }
  .tag-pill.active {
    color: var(--text);
    border-color: var(--text);
  }
  .count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    opacity: 0.6;
  }
</style>
