---
import "tocbot/dist/tocbot.css";
---

<style is:global>
  /* tocbot */
  .toc > .toc-list {
    padding-left: 0;
  }
  .toc-link {
    text-decoration: none;
    overflow: hidden;
    white-space: nowrap;
  }
  a.toc-link {
    color: var(--color-700);
    user-select: none;
    -webkit-user-drag: none;
  }
  a.toc-link:hover {
    color: var(--color-900);
  }
  a.is-active-link {
    color: var(--color-900);
  }
  .toc-link::before {
    display: none;
  }
</style>

<script>
  import tocbot from "tocbot";

  function initTocbot() {
    if (!document.querySelector(".toc")) return;
    tocbot.destroy();
    tocbot.init({
      tocSelector: ".toc",
      contentSelector: ".main-content",
      headingSelector: "h2, h3, h4",
      hasInnerContainers: true,
      scrollSmoothDuration: 250,
      headingsOffset: 20,
      scrollSmoothOffset: -20,
      scrollHandlerTimeout: 10,
    });
  }

  document.addEventListener("astro:page-load", initTocbot);
</script>
