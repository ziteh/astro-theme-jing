---
import type { CollectionEntry } from "astro:content";
import { SITE } from "@/consts";
import PostListLayout from "@/layouts/PostListLayout.astro";
import getBlogPosts from "@/utils/getPosts";
import getUniqueTags from "@/utils/getUniqueTags";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const tags = getUniqueTags(posts);

  return tags.flatMap((tag) => {
    const taggedPosts = posts.filter((post) => post.data.tags.includes(tag.name));
    const totalPages = Math.ceil(taggedPosts.length / SITE.postsPerAllPosts);

    return Array.from({ length: totalPages }, (_, i) => ({
      params: { tagId: tag.id, page: i === 0 ? undefined : String(i + 1) },
      props: {
        posts: taggedPosts.slice(i * SITE.postsPerAllPosts, (i + 1) * SITE.postsPerAllPosts),
        currentPage: i + 1,
        totalPages,
        allPosts: posts,
        activeTagId: tag.id,
      },
    }));
  });
}

interface Props {
  posts: CollectionEntry<"blog">[];
  currentPage: number;
  totalPages: number;
  allPosts: CollectionEntry<"blog">[];
  activeTagId: string;
}

const { posts, currentPage, totalPages, allPosts, activeTagId } = Astro.props;
---

<PostListLayout
  posts={posts}
  allPosts={allPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  paginationBase={`/tags/${activeTagId}`}
  activeTagId={activeTagId}
/>
