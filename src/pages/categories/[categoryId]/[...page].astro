---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import PostCard from "../../../components/PostCard.astro";
import TagPill from "../../../components/TagPill.astro";
import { SITE } from "../../../consts";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import getUniqueCategories from "../../../utils/getUniqueCategories";
import getUniqueTags from "../../../utils/getUniqueTags";
import postFilter from "../../../utils/postFilter";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(postFilter)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  const categories = getUniqueCategories(posts);

  return categories.flatMap((category) => {
    const categorizedPosts = posts.filter((post) => post.data.categories.includes(category.name));
    const totalPages = Math.ceil(categorizedPosts.length / SITE.postsPerPage);

    return Array.from({ length: totalPages }, (_, i) => ({
      params: { categoryId: category.id, page: i === 0 ? undefined : String(i + 1) },
      props: {
        posts: categorizedPosts.slice(i * SITE.postsPerPage, (i + 1) * SITE.postsPerPage),
        currentPage: i + 1,
        totalPages,
        allPosts: posts,
      },
    }));
  });
}

interface Props {
  posts: any[];
  currentPage: number;
  totalPages: number;
  allPosts: any[];
}

const { categoryId } = Astro.params;
const { posts, currentPage, totalPages, allPosts } = Astro.props;
const hasPrevPage = currentPage > 1;
const hasNextPage = currentPage < totalPages;
const prevPageUrl =
  currentPage - 1 === 1
    ? `/categories/${categoryId}`
    : `/categories/${categoryId}/${currentPage - 1}`;
const nextPageUrl = `/categories/${categoryId}/${currentPage + 1}`;
---

<BaseLayout>
  <head>
    <BaseHead title={SITE.title} description={SITE.description} />
    <style>
      ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      .content-wrapper {
        display: flex;
        gap: 2rem;
      }
      .post-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .sidebar {
        width: 140px;
        padding: 1rem;
      }
      .sidebar h2 {
        margin: 0 0 1rem 0;
        font-size: 1.25rem;
      }
      .tags {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .pagination {
        font-size: 0.85rem;
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        justify-content: center;
        align-items: center;
      }
      .pagination a,
      .pagination span {
        text-decoration: none;
      }
      .pagination .disabled {
        cursor: not-allowed;
        color: var(--text-muted);
      }
      .pagination .current {
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="content-wrapper">
        <aside class="sidebar">
          <h2>Categories</h2>
          <ul class="categories">
            {
              getUniqueCategories(allPosts).map((category) => (
                <li>
                  <a href={`/categories/${category.id}`}>
                    <span>{category.name}</span>
                    <span>{category.count}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </aside>
        <div>
          <ul class="post-list">
            {
              posts.map((post) => (
                <li>
                  <PostCard
                    id={post.id}
                    title={post.data.title}
                    description={post.data.description}
                    date={post.data.date}
                    updated={post.data.updated}
                  />
                </li>
              ))
            }
          </ul>
          <!-- Pagination -->
          {
            totalPages > 1 && (
              <nav class="pagination">
                {hasPrevPage ? (
                  <a href={prevPageUrl}>← Prev</a>
                ) : (
                  <span class="disabled">← Prev</span>
                )}
                <span class="current">
                  {currentPage} / {totalPages}
                </span>
                {hasNextPage ? (
                  <a href={nextPageUrl}>Next →</a>
                ) : (
                  <span class="disabled">Next →</span>
                )}
              </nav>
            )
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</BaseLayout>
